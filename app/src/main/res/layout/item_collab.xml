<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="4dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_person"
                    android:scaleType="centerCrop"
                    android:background="#EEEEEE"
                    android:padding="10dp"/>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/collabName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sarah Chen"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text"/>

                <TextView
                    android:id="@+id/collabHeadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product Designer"
                    android:textSize="13sp"
                    android:textColor="@color/textSecondary"
                    android:drawableStart="@drawable/ic_business"
                    android:drawablePadding="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/collabLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="San Francisco, CA"
                    android:textSize="13sp"
                    android:textColor="@color/textSecondary"
                    android:drawableStart="@drawable/location"
                    android:drawablePadding="4dp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/collabAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Passionate about creating intuitive user experiences."
            android:textColor="@color/text"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:maxLines="2"
            android:ellipsize="end"/>

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+ Connect"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="#1A237E"
            android:layout_marginTop="16dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>