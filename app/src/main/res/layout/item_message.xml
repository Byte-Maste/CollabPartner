<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/msgRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp"
    android:clipToPadding="false"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:id="@+id/msgProfileCard"
        android:layout_width="32dp"
        android:layout_height="32dp"
        app:cardCornerRadius="16dp"
        android:layout_marginEnd="8dp"
        android:layout_gravity="bottom"
        android:elevation="0dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/msgProfileImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/msgContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="10dp"
        android:paddingHorizontal="14dp"
        android:orientation="vertical"
        android:elevation="1dp"
        android:maxWidth="280dp">

        <TextView
            android:id="@+id/txtSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sender Name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FF9800"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <ImageView
            android:id="@+id/msgImage"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:id="@+id/msgFilePanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#20000000"
            android:padding="8dp"
            android:layout_marginBottom="4dp">
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_file"/>
                
            <TextView
                android:id="@+id/msgFileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="document.pdf"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginLeft="8dp"
                android:maxWidth="180dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/msgText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Message"
            android:textSize="15sp"
            android:autoLink="web"
            android:textColorLink="#2196F3"
            android:linksClickable="true"
            android:lineSpacingExtra="2dp"/>

        <TextView
            android:id="@+id/txtTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00 AM"
            android:textSize="10sp"
            android:textColor="#80000000"
            android:layout_gravity="end"
            android:layout_marginTop="2dp"/>
    </LinearLayout>
</LinearLayout>