<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="4dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/jobTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Frontend Developer"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text"
                android:layout_toLeftOf="@+id/jobTypeTag"
                android:layout_marginRight="8dp"/>

            <TextView
                android:id="@+id/jobTypeTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Collaboration"
                android:textSize="12sp"
                android:textColor="#2196F3"
                android:background="@drawable/tag_bg_blue"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/jobCompany"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TechVision AI"
            android:textColor="@color/textSecondary"
            android:textSize="14sp"
            android:drawableStart="@drawable/ic_business"
            android:drawablePadding="6dp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/jobDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Looking for a developer..."
            android:maxLines="3"
            android:ellipsize="end"
            android:textColor="@color/text"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/jobLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remote"
                android:textSize="12sp"
                android:drawableStart="@drawable/location"
                android:drawablePadding="4dp"
                android:textColor="@color/textSecondary"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/jobBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$3000-5000"
                android:textSize="12sp"
                android:drawableStart="@drawable/ic_attach_money"
                android:drawablePadding="4dp"
                android:textColor="@color/textSecondary"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/jobDeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15/12/2024"
                android:textSize="12sp"
                android:drawableStart="@drawable/calendar"
                android:drawablePadding="4dp"
                android:textColor="@color/textSecondary"/>
        </LinearLayout>

        <TextView
            android:text="Required Skills:"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/jobSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="React • JavaScript • UI/UX"
            android:textColor="@color/primary"
            android:background="@drawable/input_bg"
            android:padding="8dp"
            android:layout_marginTop="4dp"
            android:textSize="12sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtApplicants"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 applicants"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="4dp"
                android:textColor="@color/textSecondary"/>

            <Button
                android:id="@+id/btnApply"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:text="Apply Now"
                android:background="@drawable/rounded_button"
                android:textSize="12sp"/>

            <ImageView
                android:id="@+id/btnDeleteJob"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_delete"
                android:layout_marginLeft="10dp"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>